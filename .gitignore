# === SEC-RAG Local Data Storage ===
# Ignore raw filings, XBRL parse results, and processed chunks, but keep gitkeepers
data/raw_filings/*
!data/raw_filings/.gitkeep

data/xbrl/*
!data/xbrl/.gitkeep

data/processed/*
!data/processed/.gitkeep
